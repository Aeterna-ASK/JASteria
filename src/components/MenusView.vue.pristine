// 調理方法のテキストエリアで改行時に自動で番号を振る (v1.3.1)
const handleCookingInstructionsKeydown = (e) => {
const textar
// 調理方法のテキストエリアで改行時に自動で番号を振る (v1.3.1)
const textarea = e.target;
const val = textarea.value;
const start = textarea.selectionStart;

// 現在の行（カーソルがある行）を取得
const textBeforeCursor = val.substring(0, start);
const lastLineBreak = textBeforeCursor.lastIndexOf('\n');
const currentLine = textBeforeCursor.substring(lastLineBreak + 1);

// 「数字. 」で始まっているか判定
const match = currentLine.match(/^(\d+)\.\s/);
if (match) {
e.preventDefault(); // デフォルトの改行を防止
const nextNum = parseInt(match[1], 10) + 1;
const insertText = `\n${nextNum}. `;

// 文字列の挿入
form.value.cookingInstructions = val.substring(0, start) + insertText + val.substring(start);

// カーソル位置を調整
setTimeout(() => {
textarea.selectionStart = textarea.selectionEnd = start + insertText.length;
}, 0);
}
};



// --- PDF解析・アーカイブ機能 (v1.3.1 追加) ---
const selectedFile = ref(null);
const isAnalyzing = ref(false);
const archiveMenus = ref({}); // { '2024': [...], '2025': [...] }

const handlePdfUpload = (e) => {
const file = e.target.files[0];
if (file && file.type === 'application/pdf') {
selectedFile.value = file;
} else {
alert('PDFファイルを選択してください。');
}
};

const fileToBase64 = (file) => {
return new Promise((resolve, reject) => {
const reader = new FileReader();
reader.readAsDataURL(file);
reader.onload = () => {
const base64 = reader.result.split(',')[1];
resolve(base64);
};
reader.onerror = error => reject(error);
if (file && file.type === 'application/pdf') {
selectedFile.value = file;
} else {
alert('PDFファイルを選択してください。');
}
};

const fileToBase64 = (file) => {
return new Promise((resolve, reject) => {
const reader = new FileReader();
reader.readAsDataURL(file);
reader.onload = () => {
const base64 = reader.result.split(',')[1];
resolve(base64);
};
reader.onerror = error => reject(error);
});
};

// アーカイブメニューを引用して新規メニューを作成
const importArchiveMenu = (archiveMenu) => {
form.value = {
name: archiveMenu.name || '',
price: archiveMenu.price || 0,
isOrganicClaim: true,
description: archiveMenu.description || '',
recipe: [],
category: archiveMenu.category || '有機料理スペック',
changeDetails: '前年スペックからの引用',
targetCreatedDate: new Date().toISOString().split('T')[0],
startDate: new Date().toISOString().split('T')[0],
targetCreatedDate: new Date().toISOString().split('T')[0],
startDate: new Date().toISOString().split('T')[0],
reviewDate: new Date().toISOString().split('T')[0],
deadline: '',
creatorApproved: state.restaurantInfo.grader || '鈴木 美咲',
managerApproved: state.restaurantInfo.manager || '角田 健一',
courseTargetNum: '年間3600食',
singleTargetNum: '年間60食',
displayPeriod: '通年',
displayMethod: 'メニューに掲載',
displayStyle: '記号により表示',
cookingInstructions: archiveMenu.cookingInstructions || '',
remarks: ''
};
if (archiveMenu.recipe) {
archiveMenu.recipe.forEach(item => {
// PDFで指定された有機/非有機で判定、PDFに記載がない場合は食材名から判定
const isOrganic = item.isOrganic !== undefined ? item.isOrganic : item.ingredientName.includes('有機');
const targetType = isOrganic ? 'organic' : 'general';

// マスターから、名前とタイプの両方が一致する食材を探す
let matchedIng = state.ingredients.find(ing =>
(ing.name === item.ingredientName || ing.name.includes(item.ingredientName) || item.ingredientName.includes(ing.name)) &&
ing.type === targetType
);

// 名前は一致するが、タイプが異なる場合、または見つからない場合は新規作成
if (!matchedIng) {
matchedIng = restaurantStore.addIngredient({
name: item.ingredientName,
supplier: '（PDF解析自動生成）',
type: targetType,
hasCertificate: isOrganic ? false : undefined,
certificateExpiry: '',
hasJasLabel: isOrganic ? false : undefined
});
}

form.value.recipe.push({
ingredientId: matchedIng.id,
amount: item.amount
});
});
}

if (form.value.recipe.length === 0) {
addRecipeRow();
}

isEditing.value = false;
currentId.value = null;
activeFormTab.value = 'basic';
errorMessage.value = '';
showRecipeModal.value = true;
};

const analyzePdf = async () => {
if (!selectedFile.value) return;

const apiKey = state.restaurantInfo.geminiApiKey;
if (!apiKey) {
alert('店舗設定でGemini APIキーを登録してください。');
return;
}

isAnalyzing.value = true;

try {
const base64Data = await fileToBase64(selectedFile.value);

// Gemini API 呼び出し (最新のgemini-2.5-flashを使用)
const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`, {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify({
contents: [{
parts: [
{
inlineData: {
mimeType: "application/pdf",
data: base64Data
}
},
{
text: "あなたは有機JASレストランの監査スペシャリストです。提供されたPDF（料理スペック帳票）からレシピ情報を抽出し、JSON形式で返してください。\n\n【重要】PDFに記載されている「食材」「区分」「分量」の3列から、以下の情報を正確に抽出してください：\n- 食材名：PDFの「食材」列から抽出（『有機』『非有機』の接頭辞は除去して食材







































});
}

const newMenu = {
name: archiveMenu.name || '',
price: archiveMenu.price || 0,
isOrganicClaim: true,
description: archiveMenu.description || '',
recipe: [],
category: archiveMenu.category || '有機料理スペック',
changeDetails: '前年スペックからの引用',
targetCreatedDate: new Date().toISOString().split('T')[0],
startDate: new Date().toISOString().split('T')[0],
reviewDate: new Date().toISOString().split('T')[0],
deadline: '',
creatorApproved: state.restaurantInfo.grader || '鈴木 美咲',
managerApproved: state.restaurantInfo.manager || '角田 健一',
courseTargetNum: '年間3600食',
singleTargetNum: '年間60食',
displayPeriod: '通年',
displayMethod: 'メニューに掲載',
displayStyle: '記号により表示',
cookingInstructions: archiveMenu.cookingInstructions || '',
remarks: '',
year: year // 年度情報を保存
};

// 原材料の紐付け - 有機/非有機を正確に反映しながら重複を避ける
if (archiveMenu.recipe) {
archiveMenu.recipe.forEach(item => {
// PDFで指定された有機/非有機で判定、PDFに記載がない場合は食材名から判定
const isOrganic = item.isOrganic !== undefined ? item.isOrganic : item.ingredientName.includes('有機');
const targetType = isOrganic ? 'organic' : 'general';
// PDFで指定された有機/非有機で判定、PDFに記載がない場合は食材名から判定
const isOrganic = item.isOrganic !== undefined ? item.isOrganic : item.ingredientName.includes('有機');
const targetType = isOrganic ? 'organic' : 'general';

// マスターから、名前とタイプの両方が一致する食材を探す
let matchedIng = state.ingredients.find(ing =>
(ing.name === item.ingredientName || ing.name.includes(item.ingredientName) || item.ingredientName.includes(ing.name)) &&
ing.type === targetType
);

// 名前は一致するが、タイプが異なる場合、または見つからない場合は新規作成
if (!matchedIng) {
matchedIng = restaurantStore.addIngredient({
name: item.ingredientName,
supplier: '（PDF解析自動生成）',
type: targetType,
hasCertificate: isOrganic ? false : undefined,
certificateExpiry: '',
hasJasLabel: isOrganic ? false : undefined
});
}

newMenu.recipe.push({
ingredientId: matchedIng.id,
}

restaurantStore.addMenu(newMenu);
addedCount++;
});
}

alert(`${addedCount}件のレシピを自動追加しました！メニューカードを確認してください。`);
} catch (error) {
alert('分析中にエラーが発生しました: ' + error.message);
console.error(error);
} finally {
isAnalyzing.value = false;
}
};

// JAS 0004 適合表示記号（壺のマーク）の数と範囲テキスト算出ヘルパー (v1.4.0 追加)
const getTsuboCount = (ratio) => {
const r = parseFloat(ratio) || 0;
if (r >= 95) return 4;
if (r >= 80) return 3;
if (r >= 50) return 2;
return 1;
};

const getTsuboRangeText = (ratio) => {
const r = parseFloat(ratio) || 0;
if (r >= 95) return '95%以上';
if (r >= 80) return '80%以上95%未満';
if (r >= 50) return '50%以上80%未満';
return '50%未満';
};
</script>

