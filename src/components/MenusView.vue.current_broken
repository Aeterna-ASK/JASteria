    console.log('[AI Image Gen] Fetching ultra-fast model=turbo image...');
    const seed = Math.floor(Math.random() * 100000);
    const url = `https://image.pollinations.ai/prompt/${encodeURIComponent(cleanPrompt)}?width=512&height=512&nologo=true&model=turbo&seed=${seed}`;
    
    // CORSと印刷対応のため、バックグラウンドで画像バイナリをダウンロードして Base64 に同期変換！
    console.log('[AI Image Gen] Downloading and converting image to Base64 to guarantee CORS compliance...');
    const imageFetch = await fetch(url);
