    await new Promise((resolve, reject) => {
      reader.onloadend = () => {
        form.value.imageUrl = reader.result;
        console.log('[AI Image Gen] ULTIMATE SUCCESS: Generated, downloaded, and bound premium photo base64!');
        resolve();
      };
      reader.onerror = () => {
        reject(new Error('Failed to read image blob as base64'));
      };
      reader.readAsDataURL(blob);
    });

  } catch (err) {
    console.error('AI Image Gen Error:', err);
    alert(`AI画像生成に失敗しました。\nエラー内容: ${err.message || err}`);
  } finally {
