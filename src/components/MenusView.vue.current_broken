    }).filter(Boolean).join(', ');

    console.log(`[AI Image Gen] Recipe ingredients: "${ingredientList}"`);

    // デフォルトのプロンプト構築
    let cleanPrompt = `plain white background simple white ceramic plate containing ${dishName} only scientific food catalog photography`;

    // 2. Gemini API キーがある場合、手本画像（ある場合）と食材を基に、WAF安全で詳細な英語プロンプトを分析・生成
    if (apiKey) {
      console.log('[AI Image Gen] Gemini API key found. Generating visual styling prompt via Gemini 2.5 Flash...');
      try {
        const promptGenRequest = `You are a world-class prompt engineer for AI image generation (Stable Diffusion/FLUX).
Based on the dish name "${dishName}" and its specific ingredients list: "${ingredientList}", generate a VERY SHORT, scientific-style food catalog photography prompt in English.

CRITICAL RULES:
1. Output MUST be under 15 words. Keep it extremely concise.
2. Use ONLY plain English words and spaces. Absolutely NO commas (,), colons (:), brackets, or other special symbols.
3. Ensure the prompt forces a plain, clean white background (e.g. starting with "plain white background simple white plate containing") and absolutely NO cutlery, forks, napkins, tables, windows, or background clutter.
4. Strictly restrict the food to ONLY the listed ingredients: "${ingredientList}". Do NOT allow the AI to add unlisted ingredients or garnishes.
5. Translate any Japanese culinary terms into descriptive English (e.g., "Nukazuke" -> "Japanese rice bran pickled vegetables").
6. Do NOT use buzzwords like "gourmet", "professional", "hyper realistic". Output ONLY the raw prompt string.`;

        let geminiContents = [];
        if (form.value.sampleImageUrl) {
          console.log('[AI Image Gen] Style guide sample image found! Performing Image-to-Text style profiling...');
          const base64Parts = form.value.sampleImageUrl.split(';base64,');
          const mimeType = base64Parts[0].split(':')[1] || 'image/jpeg';
          const base64Data = base64Parts[1] || base64Parts[0];

          geminiContents = [{
            parts: [
              { text: promptGenRequest + `\n\nCRITICAL MULTIMODAL INSTRUCTION: Analyse the attached sample image. You MUST extract its visual style, plating layout, angle, container color/shape, and texture, and embed these visual style cues directly into your generated prompt, so that the T2I generator can reproduce a highly similar visual look, but containing ONLY the specified ingredients: "${ingredientList}".` },
              {
                inlineData: {
                  mimeType: mimeType,
                  data: base64Data
                }
              }
            ]
          }];
        } else {
          geminiContents = [{
            parts: [{ text: promptGenRequest }]
          }];
        }

        const promptResponse = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: geminiContents
          })
        });

        if (promptResponse.ok) {
          const result = await promptResponse.json();
          if (result.candidates && result.candidates[0]?.content?.parts[0]?.text) {
            let geminiPrompt = result.candidates[0].content.parts[0].text.trim();
            geminiPrompt = geminiPrompt.replace(/^```[a-z]*\n/, '').replace(/\n```$/, '').trim();
            geminiPrompt = geminiPrompt.replace(/[,:;()[\\]"']/g, ' ');
            
            const words = geminiPrompt.split(/\s+/);
            if (words.length > 15) {
              cleanPrompt = words.slice(0, 15).join(' ');
            } else {
              cleanPrompt = geminiPrompt;
            }
            console.log(`[AI Image Gen] Gemini generated WAF-safe recipe prompt: "${cleanPrompt}"`);
          }
        } else {
          const errData = await promptResponse.json();
          throw new Error(errData.error?.message || 'Gemini prompt generation failed');
        }
      } catch (geminiErr) {
        console.warn('[AI Image Gen] Gemini prompt generation failed, using basic prompt:', geminiErr);
        let simpleEnglishDish = 'organic food';
        if (dishName.includes('ぬか漬け') || dishName.includes('漬物')) {
          simpleEnglishDish = 'Japanese pickled vegetables';
