    <div class="view-header mb-6">
      <div class="header-title">
        <h2 class="flex items-center gap-2"><Sprout :size="24" /> 蜴滓攝譁吶・繧�E�繧�E�繝ｼ邂｡送E�E</h2>
        <p class="text-sub">莉募・繧後ｋ縺吶∋縺�E�縺�E�蜴滓攝譁吶�E�逋ｻ骭�E�縺励∵怏讖櫟AS險�E�譏取嶌繧・�E��E�莉倩�E��E�遉ｺ・・AS繝槭・繧�E�・峨・譛�E┌繧堤�E��E�送E�E�E�縺�E�縺吶・<</p>
      </div>
      <div style="display: flex; gap: 0.75rem; align-items: center;">
        <button 
          class="btn btn-outline flex items-center gap-2" 
          style="border-color: var(--primary); color: var(--primary); font-weight: 600;" 
          @click="handleSyncFromRiRyLink" 
          :disabled="isSyncing"
        >
          <RefreshCw :size="16" :class="isSyncing ? 'animate-spin' : ''" />
          {{ isSyncing ? '蜷梧悁E���E�...' : 'Ri-Ry-Link縺�E�蜷梧悁E' }}
        </button>
        <button class="btn btn-primary" @click="openAddModal">
          <Plus :size="18" /> 譁E��隕丞次譚�E侭逋ｻ骭�E�
        </button>
      </div>
    </div>

    <!-- 蜷梧悁E��先棡騾夂衁E(縺翫�E�縺�E�縺�E�縺鈴夂衁E -->
    <Transition name="fade">
      <div v-if="syncResult" class="alert alert-success py-3 px-4 mb-6 text-sm flex items-center justify-between" style="border-left: 4px solid #16a34a; background: rgba(22, 163, 74, 0.05); border-radius: var(--radius-sm); display: flex; justify-content: space-between; width: 100%;">
        <div style="display: flex; align-items: center; gap: 0.5rem; color: #16a34a; font-weight: 500;">
          <Check :size="18" />
          <span>{{ syncResult }}</span>
        </div>
        <button class="btn-close" style="padding: 0; background: none; border: none; cursor: pointer; color: #16a34a;" @click="syncResult = null">
          <X :size="16" />
        </button>
      </div>
    </Transition>
    
    <Transition name="fade">
      <div v-if="syncError" class="alert alert-danger py-3 px-4 mb-6 text-sm flex items-center justify-between" style="border-left: 4px solid #dc2626; background: rgba(220, 38, 38, 0.05); border-radius: var(--radius-sm); display: flex; justify-content: space-between; width: 100%;">
        <div style="display: flex; align-items: center; gap: 0.5rem; color: #dc2626; font-weight: 500;">
          <AlertTriangle :size="18" />
          <span>{{ syncError }}</span>
        </div>
        <button class="btn-close" style="padding: 0; background: none; border: none; cursor: pointer; color: #dc2626;" @click="syncError = null">
          <X :size="16" />
        </button>
      </div>
    </Transition>

    <!-- 讀懁E���E� & 繝輔ぅ繝ｫ繧�E�繝ｼ繝�E・ -->
    <div class="filter-bar card mb-6">
      <div class="search-input-wrapper">
        <Search class="search-icon" :size="18" />
        <input 
          v-model="searchQuery" 
          type="text" 
          placeholder="蜴滓攝譁吝錐縲∽�E�募�E蜈医〒讀懁E���E�..." 
          class="input-organic"
        />
      </div>
      <div class="filter-options">
        <label class="filter-label">蛹�E�蛻・�E�・</label>
        <div class="filter-buttons">
          <button 
            :class="['filter-btn', filterType === 'all' ? 'active' : '']" 
            @click="filterType = 'all'"
          >
            縺吶∋縺�E�
          </button>
          <button 
            :class="['filter-btn', filterType === 'organic' ? 'active' : '']" 
            @click="filterType = 'organic'"
          >
            譛画�E�櫟AS隱榊ｮ壼刀
          </button>
          <button 
            :class="['filter-btn', filterType === 'general' ? 'active' : '']" 
            @click="filterType = 'general'"
          >
            荳闊ｬ鬟溷刀
          </button>
          <button 
            :class="['filter-btn', filterType === 'salt_water' ? 'active' : '']" 
            @click="filterType = 'salt_water'"
          >
            豌ｴ繝ｻ鬟溷�E��E� (險育�E�鈴勁螟・
          </button>
        </div>
      </div>
    </div>

    <!-- 蜴滓攝譁吶ユ繝ｼ繝悶΁E-->
          <div class="table-container">

      <table class="table-organic">
        <thead>
          <tr>
            <th>蜴滓攝譁吝錁E</th>
            <th>蛹E・</th>
            <th>莉募・蜈�E</th>
            <th>JAS險�E�譏取嶁E</th>
            <th>險�E�譏取嶌譛牙柑譛滁E��</th>
            <th>JAS陦�E�遉ｺ譛�E━E</th>
            <th style="width: 100px; text-align: center;">謫堺</th>
          </tr>
        </thead>
        <tbody>
          <tr v-if="filteredIngredients.length === 0">
            <td colspan="7" class="text-center text-light py-8">
              隧�E�蠖薙☁E��句次譚�E侭縺瑚ｦ九▽縺九ｊ縺�E�縺帙ｓ縺�E�縺励◁E��・            </td>
          </tr>
          <tr v-for="ing in filteredIngredients" :key="ing.id" :class="checkExpiryStatus(ing.certificateExpiry, ing.type) === 'expired' ? 'row-expired' : ''">
            <td>
              <div class="font-semibold">{{ ing.name }}</div>
              <span class="id-badge">{{ ing.id }}</span>
            </td>
            <td>
              <span v-if="ing.type === 'organic'" class="badge badge-success">譛画�E�櫟AS蜩・</span>
              <span v-else-if="ing.type === 'general'" class="badge badge-neutral">荳闊ｬ鬟溷刀</span>
              <span v-else-if="ing.type === 'salt_water'" class="badge badge-warning">豌ｴ繝ｻ鬟溷�E��E�</span>
            </td>
            <td>{{ ing.supplier }}</td>
            <td>
              <span v-if="ing.type === 'organic'" class="flex items-center gap-1 text-sm font-medium">
                <template v-if="ing.jasCertUrl || ing.certUrl">
                  <Check class="text-success" :size="16" />
                  <a href="#" @click.prevent="openSecureCertificate(ing.jasCertUrl || ing.certUrl)" class="text-primary hover:underline font-bold" title="繧�E�繝ｪ繝�Eけ縺励※險�E�譏取嶌繧定｡�E�遉ｺ繝ｻ蜊ｰ蛻�E�" style="color: var(--primary); display: inline-flex; align-items: center; gap: 0.15rem;">
                    謠仙�E貂�E���塁E                  </a>
                </template>
                <template v-else>
                  <X class="text-danger" :size="16" />
                  <span class="text-danger font-semibold">譛ｪ謠仙�E</span>
                </template>
              </span>
              <span v-else class="text-light text-sm">-</span>
            </td>
            <td>
              <span v-if="ing.type === 'organic' && ing.hasCertificate" class="flex items-center gap-1 font-mono text-sm">
                <Calendar :size="14" class="text-sub" />
                <span :class="[
                  checkExpiryStatus(ing.certificateExpiry, ing.type) === 'expired' ? 'text-danger font-bold' : '',
                  checkExpiryStatus(ing.certificateExpiry, ing.type) === 'warning' ? 'text-warning font-bold' : ''
                ]">
                  {{ ing.certificateExpiry }}
                </span>
                <span v-if="checkExpiryStatus(ing.certificateExpiry, ing.type) === 'expired'" class="small-alert">
                  [譛滁E��蛻・�E�]
                </span>
                <span v-else-if="checkExpiryStatus(ing.certificateExpiry, ing.type) === 'warning'" class="small-alert warn">
                  [霑第律譛滁E��]
                </span>
              </span>
              <span v-else class="text-light text-sm">-</span>
            </td>
            <td>
              <span v-if="ing.type === 'organic'" class="flex items-center gap-1 text-sm font-medium">
                <Check v-if="ing.hasJasLabel" class="text-success" :size="16" />
                <X v-else class="text-danger" :size="16" />
                {{ ing.hasJasLabel ? 'JAS繝槭・繧�E�譛�E' : '陦�E�遉ｺ縺�E�縺・' }}
              </span>
              <span v-else class="text-light text-sm">-</span>
            </td>
            <td style="text-align: center;">
