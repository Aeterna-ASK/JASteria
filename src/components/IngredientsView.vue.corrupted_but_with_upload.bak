<script setup>
import { ref, computed } from 'vue';
import { restaurantStore } from '../store/restaurantStore';
import { 
  Sprout, 
  Plus, 
  Trash2, 
  Edit3, 
  AlertTriangle, 
  Calendar, 
  Search,
  Check,
  X,
  PlusCircle,
  HelpCircle,
  RefreshCw // 譁E��隕剰�E��E�蜉
} from 'lucide-vue-next';

const state = restaurantStore.state;
const ingredients = computed(() => state.ingredients);

// 讀懁E���E� & 繝輔ぅ繝ｫ繧�E�繝ｼ
const searchQuery = ref('');
const filterType = ref('all'); // all, organic, general, salt_water

const filteredIngredients = computed(() => {
  return ingredients.value.filter(ing => {
    const matchesSearch = ing.name.toLowerCase().includes(searchQuery.value.toLowerCase()) || 
                          ing.supplier.toLowerCase().includes(searchQuery.value.toLowerCase());
    const matchesFilter = filterType.value === 'all' || ing.type === filterType.value;
    return matchesSearch && matchesFilter;
  });
});

// 繝｢繝ｼ繝繝ｫ繝ｻ繝輔か繝ｼ繝迥�E�諷・const showModal = ref(false);
const isEditing = ref(false);
const currentId = ref(null);

const form = ref({
  name: '',
  supplier: '',
  type: 'organic', // organic, general, salt_water
  hasCertificate: true,
  certificateExpiry: '',
  hasJasLabel: true
});

const errorMessage = ref('');

// 繝｢繝ｼ繝繝ｫ繧�E�繝ｼ繝励Φ (譁E��隕�E
const openAddModal = () => {
  isEditing.value = false;
  currentId.value = null;
  form.value = {
    name: '',
    supplier: '',
    type: 'organic',
    hasCertificate: true,
    certificateExpiry: '',
    hasJasLabel: true,
    jasCertUrl: ''
  };
  errorMessage.value = '';
  showModal.value = true;
};

// 繝｢繝ｼ繝繝ｫ繧�E�繝ｼ繝励Φ (邱�E�髮・
const openEditModal = (ing) => {
  isEditing.value = true;
  currentId.value = ing.id;
  form.value = {
    name: ing.name,
    supplier: ing.supplier,
    type: ing.type,
    hasCertificate: ing.hasCertificate,
    certificateExpiry: ing.certificateExpiry,
    hasJasLabel: ing.hasJasLabel,
    jasCertUrl: ing.jasCertUrl || ing.certUrl || ''
  };
  errorMessage.value = '';
  showModal.value = true;
};

// JASマ�Eク・証明書写真のアチE�Eロード�E琁E
const handleJasCertUpload = (event) => {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    form.value.jasCertUrl = e.target.result;
  };
  reader.readAsDataURL(file);
};

// 菫晏ｭ倥ぁE���E�繧�E�繝ｧ繝ｳ
const saveIngredient = () => {
  if (!form.value.name.trim()) {
      errorMessage.value = '蜴滓攝譁吝錐繧貞E蜉帙＠縺E縺上□縺輔＞';
    return;
  }
  if (!form.value.supplier.trim()) {
    errorMessage.value = '莉募・蜈医�E�蜈�E�蜉帙＠縺�E�縺上□縺輔＞縲・';
    return;
  }
  if (form.value.type === 'organic' && form.value.hasCertificate && !form.value.certificateExpiry) {
    errorMessage.value = '譛画�E�溷玁E��・°縺�E�險�E�譏取嶌譛峨�E�縺�E�蝣�E�蜷医・縲∵怏蜉�E�譛滁E��繧貞�E蜉帙＠縺�E�縺上□縺輔＞縲・';
    return;
  }

  try {
    if (isEditing.value) {
      restaurantStore.updateIngredient(currentId.value, form.value);
    } else {
      restaurantStore.addIngredient(form.value);
    }
    showModal.value = false;
  } catch (err) {
    errorMessage.value = err.message;
  }
};

// 蜑企勁繧�E�繧�E�繧�E�繝ｧ繝ｳ
const deleteIngredient = (id, name) => {
  if (confirm(`蜴滓攝譁吶€・${name}縲阪E蜑企勁縺励※繧めEE繧阪E縺・〒縺吶°・`)) {
    try {
      restaurantStore.deleteIngredient(id);
    } catch (err) {
      alert(err.message);
    }
  }
};

// 險�E�譏取嶌譛滁E��蛻・�E�繝�Eぉ繝�EぁE
const checkExpiryStatus = (expiryDate, type) => {
  if (type !== 'organic' || !expiryDate) return 'none';
  const today = new Date();
  const expiry = new Date(expiryDate);
  const warningLimit = new Date();
  warningLimit.setDate(today.getDate() + 30);

  if (expiry <= today) return 'expired';
  if (expiry <= warningLimit) return 'warning';
  return 'good';
};

// Ri-Ry-Link 縺九ｉ縺�E�譛画�E�溷次譚�E侭蜷梧悁E���E�繝�E・繝�E(繝ｦ繝ｼ繧�E�繝ｼ謚ｼ荳区凾縺�E�縺�E�蜍穂ｽ懊�E繧句�E�牙�E繝ｻ霁E��驥剰�E��E�險・
const isSyncing = ref(false);
const syncResult = ref(null);
const syncError = ref(null);

// 隱崎ｨ�E�繝｢繝ｼ繝繝ｫ髢�E�騾�E�繧�E�繝�E・繝�E(遒ｺ螳溘�E螳溘ョ繝ｼ繧�E�隱�E�縺�E�霎ｼ縺�E�逕ｨ)
const showAuthModal = ref(false);
const authForm = ref({
  email: '',
  password: ''
});
const authError = ref('');
const isAuthenticating = ref(false);


const handleSyncFromRiRyLink = async () => {
  isSyncing.value = true;
  syncResult.value = null;
  syncError.value = null;
  authError.value = '';
  try {
    const res = await restaurantStore.syncFromRiRyLink();
    if (res.requiresAuth) {
      // 譛ｪ繝ｭ繧�E�繧�E�繝ｳ縺�E�蝣�E�蜷医・縲∬�E�崎ｨ�E�繝繧�E�繧�E�繝ｭ繧�E�繧定｡�E�遉ｺ縺吶�E�E      showAuthModal.value = true;
    } else {
      syncResult.value = res.message;
      // 7遘貞ｾ後�E騾夂衍繧定�E蜍墓ｶ亥悁E(縺翫�E�縺�E�縺�E�縺誘X)
      setTimeout(() => {
        syncResult.value = null;
      }, 7000);
    }
  } catch (err) {
    console.error(err);
    syncError.value = err.message || 'Ri-Ry-Link縺九ｉ縺�E�蜷梧悁E���E�螟ｱ謨励�E�縺�E�縺励◁E��・';
  } finally {
    isSyncing.value = false;
  }
};

const submitAuthAndSync = async () => {
  if (!authForm.value.email.trim() || !authForm.value.password.trim()) {
    authError.value = '繝｡繝ｼ繝ｫ繧�E�繝峨Ξ繧�E�縺�E�繝代せ繝ｯ繝ｼ繝峨�E�蜈�E�蜉帙＠縺�E�縺上□縺輔＞縲・';
    return;
  }
  
  isAuthenticating.value = true;
  authError.value = '';
  try {
    const res = await restaurantStore.syncFromRiRyLink(authForm.value.email, authForm.value.password);
    if (res.requiresAuth) {
      authError.value = '繝ｭ繧�E�繧�E�繝ｳ縺�E�螟ｱ謨励�E�縺�E�縺励◁E��めE��繧�E�繧�E�繝ｳ繝域ュ蝣�E�繧偵�E�縺・�E�蠎ｦ縺顔｢�E�縺九ａ縺上□縺輔＞縲・';
    } else {
      // 繝ｭ繧�E�繧�E�繝ｳ・・酔譛溷�E�御�E�・      showAuthModal.value = false;
      syncResult.value = res.message;
      // 蜈･蜉帙ヵ繧�E�繝ｼ繝繧�E�繝ｪ繧�E�
      authForm.value.email = '';
      authForm.value.password = '';
      
      setTimeout(() => {
        syncResult.value = null;
      }, 7000);
    }
  } catch (err) {
    console.error(err);
    authError.value = err.message || '繧�E�繧�E�繝ｳ繧�E�繝ｳ縺�E�螟ｱ謨励�E�縺�E�縺励◁E��・';
  } finally {
    isAuthenticating.value = false;
  }
};

const selectQuickAccount = (email) => {
  authForm.value.email = email;
};

// 螳牙�E縺九▽蜷梧悁E��・�E�医・繝�E・繧�E�繝�E・繝悶Ο繝�Eけ蝗樣∩・峨↓蛻�E�繧�E�繝悶〒險�E�譏取嶌繧定｡�E�遉ｺ繝ｻ蜊ｰ蛻�E�縺吶�E�髢�E�謨�E�
const openSecureCertificate = (fileUrl) => {
  if (!fileUrl) return;
  try {
    let targetUrl = fileUrl;
    
    // Base64繝�E・繧�E�URL縺�E�蝣�E�蜷医。lob URL縺�E�螟画鋤縺励※繝悶Λ繧�E�繧�E�縺�E�繧�E�繧�E�繝･繝ｪ繝�EぁE���E�髯・data:縺�E�繝医ャ繝励Ξ繝吶Ν繝翫ン繧�E�繝ｼ繧�E�繝ｧ繝ｳ遖∵�E��E�)繧貞屓驕ｿ
    if (fileUrl.startsWith('data:')) {
      const parts = fileUrl.split(',');
      const mime = parts[0].match(/:(.*?);/)[1];
      const bstr = atob(parts[1]);
      let n = bstr.length;
      const u8arr = new Uint8Array(n);
      while (n--) {
        u8arr[n] = bstr.charCodeAt(n);
      }
      const blob = new Blob([u8arr], { type: mime });
      targetUrl = URL.createObjectURL(blob);
    }
    
    const newWindow = window.open(targetUrl, '_blank');
    if (!newWindow) {
      alert('繝昴ャ繝励ぁE���E・縺後ヶ繝ｭ繝�Eけ縺輔ｌ縺�E�縺励◁E��めE��繝ｩ繧�E�繧�E�縺�E�繧�E�繝峨Ξ繧�E�繝�E・蜿�E�蛛ｴ縺�E�縺めE��繝昴ャ繝励ぁE���E・繝悶Ο繝�Eけ險�E�螳壹�E�遒�E�隱阪�E�縲√！E���E�繧�E�繧�E�繝医〒縺�E�繝昴ャ繝励ぁE���E・繧定ｨ�E�蜿�E�縺励※縺上□縺輔＞縲・);
    }
  } catch (err) {
    console.error('險�E�譏取嶌縺�E�陦�E�遉ｺ繧�E�繝ｩ繝ｼ:', err);
    alert('險�E�譏取嶌縺�E�陦�E�遉ｺ縺�E�螟ｱ謨励�E�縺�E�縺励◁E ' + err.message);
  }
};
</script>

<template>
