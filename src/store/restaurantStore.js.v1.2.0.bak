    id: `cook-${Date.now().toString().slice(-3)}-${Math.random().toString(36).slice(2, 5)}`,
    date: log.date || new Date().toISOString().split('T')[0],
    menuId: log.menuId,
    quantity: Number(log.quantity) || 0,
