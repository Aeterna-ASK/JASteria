}

function updateCookingLog(id, updatedFields) {
  const idx = state.cookingLogs.findIndex(c => c.id === id);
  if (idx !== -1) {
    state.cookingLogs[idx] = {
      ...state.cookingLogs[idx],
      ...updatedFields
    };
    saveStore();
    return true;
  }
  return false;
}

function deleteCookingLog(id) {
  const idx = state.cookingLogs.findIndex(c => c.id === id);
  if (idx !== -1) {
